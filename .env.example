# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=elder_notification_db

# Individual Database Names
AUTH_DB_NAME=elder_auth_db
PROFILE_DB_NAME=elder_profile_db
VITALS_DB_NAME=elder_vitals_db
MEDIA_DB_NAME=elder_media_db
AUDIT_DB_NAME=elder_audit_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_DB_NAME=elder_cache_db

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=elder-connect-api
STREAM_BROKER_NAME=elder_stream_broker
KAFKA_GROUP_ID=elder-connect-group

# JWT Configuration (REQUIRED - Generate a strong secret)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=24h

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=elderconnect-bucket

# Twilio Configuration (Optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase Configuration (Optional)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Application Configuration
PORT=3000
NODE_ENV=development
API_VERSION=v1

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=elder-connect-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Prometheus Configuration
PROMETHEUS_PORT=9090

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,audio/mpeg

# N8N Webhooks (Optional)
N8N_WEBHOOK_URL=<-- YOUR n8n webhook URL -->
N8N_API_KEY=<-- YOUR n8n API KEY -->

# Razorpay Configuration (Optional)
RAZORPAY_KEY_ID=<-- YOUR Razorpay Key ID -->
RAZORPAY_KEY_SECRET=<-- YOUR Razorpay Key Secret -->

# Flagsmith Configuration (Optional)
FLAGSMITH_ENVIRONMENT_KEY=your-flagsmith-environment-key

# Email Configuration (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@elderconnect.com
SMTP_FROM_NAME=ElderConnect

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:8081

HUGGINGFACE_API_KEY=<-- YOUR HF API KEY -->